BOT_TOKEN=your_bot_token_here

# Session security key for dashboard auth cookies
SECRET_KEY=replace_with_random_long_secret

# Google OAuth (Web application credentials)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Optional: lock dashboard access to one Google email
ALLOWED_EMAIL=you@example.com

# Optional: footer link under bot posts
POST_SIGNATURE_LINK=https://t.me/obwepit
